# Copy to .env locally. Never commit the real .env.

# Database
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
DB_NAME=trkotarun_ai

# AI
GEMINI_API_KEY=your-google-aistudio-api-key
GEMINI_MODEL=gemini-flash-latest

# Auth (production: set a long random string; dev: leave blank → auto-generated per process)
JWT_SECRET=

# Environment
APP_ENV=development

# CORS — JSON list of allowed origins. Use ["*"] only in dev.
# In production: ["https://yourdomain.com","https://www.yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000"]

# Rate limits (requests per minute per IP)
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_AI_PER_MIN=15

# Payments (Razorpay) — get from https://dashboard.razorpay.com/app/keys
# Until your Razorpay account is KYC-approved, set MOCK_PAYMENTS=true to test
# the subscription flow without real money.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
MOCK_PAYMENTS=true
TRIAL_DAYS=3

# Google Sign-In — OAuth 2.0 Client ID (same value as NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend)
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Admin dashboard access — the JWT account with this email can view /admin/stats
# (counts, revenue, subscribers, recent signups). Leave empty to disable the dashboard.
ADMIN_EMAIL=
