# Copy to .env.local. Never commit the real env file.

# Backend API base URL.
# Local dev:   http://localhost:8000/api/v1
# Production:  https://trkfly-api.onrender.com/api/v1   (your Render URL)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Google Sign-In OAuth 2.0 Client ID (Web app)
# Get from: https://console.cloud.google.com/apis/credentials
# Authorized JS origins must include: https://trkflyai.com, https://www.trkflyai.com, http://localhost:3000
# Leave EMPTY to hide the Google Sign-In button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
